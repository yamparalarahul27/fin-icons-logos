# Copy to apps/web/.env.local and fill in to enable the cloud backends.
# With NONE of these set, the app falls back to local filesystem storage
# (public/overrides/) + a JSON sidecar (data/overrides.json) — no creds needed.

# --- Cloudflare R2 (override image bytes) ---------------------------------
# All five required to switch image storage from local disk to R2.
# Endpoint is derived as https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fin-icons-logos
# Public base URL of the bucket: the r2.dev domain or your CDN custom domain.
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
# Optional key prefix within the bucket (default: overrides)
R2_KEY_PREFIX=overrides

# --- Supabase (override records / metadata) -------------------------------
# Both required to switch the override store from the JSON sidecar to Postgres.
# Use the SERVICE ROLE key (server-side only — never expose to the browser).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin auth (stopgap shared-secret gate, SECURITY-PLAN.md §1) -----------
# Gates /admin and /api/admin/*. In production an UNSET secret denies all admin
# access (fail-closed); in dev, admin is open when unset.
# The login UI is a 4-digit PIN, so set a 4-digit value, e.g. ADMIN_SECRET=4821.
# (A PIN is low-entropy — brute-force resistance relies on the login rate limit;
#  enable Upstash so that limit is enforced across instances.)
ADMIN_SECRET=

# --- Rate limiting (Upstash Redis, SECURITY-PLAN.md §3) ---------------------
# Optional. With both set, rate limits use Upstash (shared, atomic, survives
# deploys). Unset → an in-memory per-instance fallback (resets on deploy).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
