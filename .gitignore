apps/web/.next/
apps/web/next-env.d.ts
apps/web/out/

# Admin-uploaded override images. The durable curation record is
# apps/web/data/overrides.json (committed); the binaries are regenerable from it
# once R2/CDN storage lands (Phase 2).
apps/web/public/overrides/
